# Environment variables for Docker Compose
# Copy this to .env and update with your values

# Frontend
# Set to the public-facing URL where the site is served (e.g. https://jobrythm.io)
VITE_API_URL=http://localhost:8081

# Optional: Override the canonical site URL for SEO/OG tags (defaults to https://jobrythm.io)
# VITE_SITE_URL=https://jobrythm.io

# Optional: "Book a demo" destination URL (e.g. a Calendly link). Defaults to /contact if not set.
# VITE_DEMO_URL=https://calendly.com/jobrythm/demo
