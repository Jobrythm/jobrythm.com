# Environment variables for Docker Compose
# Copy this to .env and update with your values

# Database
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=your_secure_password_here

# Strapi Keys (generate secure random strings)
APP_KEYS=generate_random_key1,generate_random_key2,generate_random_key3,generate_random_key4
API_TOKEN_SALT=generate_random_api_token_salt
ADMIN_JWT_SECRET=generate_random_admin_jwt_secret
TRANSFER_TOKEN_SALT=generate_random_transfer_salt
JWT_SECRET=generate_random_jwt_secret

# Frontend
VITE_API_URL=http://localhost:1337
